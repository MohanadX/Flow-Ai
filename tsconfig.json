{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,    // Catch missing array/object index references
    "allowUnreachableCode": false,       // Block dead/unreachable code builds
    "noImplicitReturns": true,           // Ensure all code paths return a value
    "noUnusedLocals": true,              // Flag unused local variables
    "noUnusedParameters": true,          // Flag unused function arguments
    "noFallthroughCasesInSwitch": true,  // Stop switch blocks from bleeding down
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
